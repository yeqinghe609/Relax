#
# Machine-local config for the DeepEyes V2 agentic example.
#
# Setup:
#   cp env.sh.example env.sh
#   # edit env.sh — at minimum set DATA_DIR; everything else is optional
#
# env.sh is gitignored. The launcher scripts + prepare.sh + harness all
# auto-source it. Put per-host paths / endpoints / proxies / mirrors here so
# they don't end up in committed code.

# ============================================================================
# REQUIRED
# ============================================================================

# Workspace root. scripts/prepare.sh lays out:
#   ${DATA_DIR}/sif/deepeyes_v2_kernel.sif
#   ${DATA_DIR}/data/{raw/,perception_all_*.parquet,reason.parquet,…,smoke.parquet}
export DATA_DIR=/path/to/your/workspace/deepeyes-v2

# ============================================================================
# Required for scripts/smoke.sh + scripts/run_single_session.py
# ============================================================================

# Chat-completions endpoint. Any OpenAI-compatible host works (SGLang, vLLM, MaaS, …).
# export OPENAI_BASE_URL=http://your-sglang-host:30000/v1
# export OPENAI_API_KEY=dummy            # SGLang doesn't validate
# Model id sent to the endpoint. Default "model" works for SGLang (model arg ignored);
# set to the real model name for MaaS/vLLM/etc.
# export OPENAI_MODEL=qwen3-vl-235b-a22b-instruct

# Where run_agent_app.sh persists agent stderr for FAILED sessions. Successful
# sessions delete their log on exit, so this dir only fills up with the
# trajectories you actually want to inspect. Default: ${EXAMPLE_DIR}/logs/agent_sessions.
# export RELAX_AGENT_LOG_DIR=/path/to/agent/logs

# ============================================================================
# Optional — outbound HTTPS proxy for scripts/prepare.sh HF downloads
# ============================================================================
# Set if huggingface.co is unreachable directly from this host.
# export HF_HTTP_PROXY=http://your.proxy.host:3128
# export HF_NO_PROXY=127.0.0.1,localhost,your.internal.hosts

# ============================================================================
# Optional — SIF build mirrors (only if docker hub + pypi.org are blocked)
# ============================================================================
# Override the base docker image fetched at build time.
# export BOOTSTRAP_FROM_IMAGE=your.docker.mirror/library/python:3.11-slim

# Override pip's index inside the SIF build.
# export BOOTSTRAP_PIP_INDEX_URL=http://your.pypi.mirror/simple
# export BOOTSTRAP_PIP_TRUSTED_HOST=your.pypi.mirror

# ============================================================================
# Optional — HuggingFace endpoint
# ============================================================================
# Default is https://huggingface.co. Override to a mirror only if you've
# verified the mirror serves the full dataset (some mirrors 308-redirect
# large files back to upstream, which huggingface_hub refuses).
# export HF_ENDPOINT=https://your.hf.mirror
